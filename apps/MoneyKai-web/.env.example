# MoneyKai Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# FastAPI Backend Configuration
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# Feature placeholders. Keep disabled until the backend/OAuth contracts are wired for web.
EXPO_PUBLIC_GMAIL_SYNC_ENABLED=false
EXPO_PUBLIC_PDF_STATEMENT_PARSING_ENABLED=false
EXPO_PUBLIC_FINANCIAL_AI_ENABLED=false
EXPO_PUBLIC_WEALTH_TAB_ENABLED=true

# App Store Review Links
# Optional. If omitted, MoneyKai falls back to store search results.
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=

# Optional: Web Google sign-in uses the provider configured in Firebase Auth

# Optional: Enable debug mode
EXPO_PUBLIC_DEBUG=false

