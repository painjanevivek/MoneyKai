# MoneyKai Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
# Keep the Firebase project auth domain here. On moneykai.com, the web app
# proxies Firebase auth helpers and uses moneykai.com as the runtime authDomain.
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# MoneyKai API configuration
# For local Expo web against a separate backend, use http://localhost:8000.
# Production should point to the deployed MoneyKai FastAPI backend.
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# Financial feature flags. Gmail requires the backend GMAIL_FEATURE_ENABLED flag
# and Google OAuth redirect URI to be configured for the same backend origin.
EXPO_PUBLIC_GMAIL_SYNC_ENABLED=true
EXPO_PUBLIC_PDF_STATEMENT_PARSING_ENABLED=false
EXPO_PUBLIC_FINANCIAL_AI_ENABLED=true
EXPO_PUBLIC_WEALTH_TAB_ENABLED=true

# App Store Review Links
# Optional. If omitted, MoneyKai falls back to store search results.
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=

# Optional: Web Google sign-in uses the provider configured in Firebase Auth

# Optional: Enable debug mode
EXPO_PUBLIC_DEBUG=false

# Sentry Monitoring
# EXPO_PUBLIC_SENTRY_DSN is safe for browser use. Keep SENTRY_AUTH_TOKEN,
# Stripe, OpenRouter, and Firebase Admin secrets in the deployment provider,
# not in this client env file.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_DEBUG=false
