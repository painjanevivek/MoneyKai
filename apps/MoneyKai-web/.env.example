# MoneyKai Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# MoneyKai API configuration
# In Vercel production, omit this to use the same-origin /api routes.
# For local Expo web against a separate backend, use http://localhost:8000.
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# AI Attachment Review (server-only; never expose with EXPO_PUBLIC_)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
AI_ATTACHMENT_TOKEN_SECRET=

# Stripe Billing (server-only values are read by /api/billing/* on Vercel)
# Prefer STRIPE_RESTRICTED_KEY with the minimum permissions needed for Checkout,
# Customers, Subscriptions, Prices, and Billing Portal. Do not expose this with
# an EXPO_PUBLIC_ prefix.
STRIPE_RESTRICTED_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_ANNUAL_PRICE_ID=
STRIPE_AUTOMATIC_TAX_ENABLED=true
MONEYKAI_SITE_URL=http://localhost:8081

# Server-side Firebase token verification for billing endpoints.
# Use the same Firebase project as the public web app config.
FIREBASE_PROJECT_ID=your-project-id

# Financial feature flags. Gmail requires the backend GMAIL_FEATURE_ENABLED flag
# and Google OAuth redirect URI to be configured for the same backend origin.
EXPO_PUBLIC_GMAIL_SYNC_ENABLED=true
EXPO_PUBLIC_PDF_STATEMENT_PARSING_ENABLED=false
EXPO_PUBLIC_FINANCIAL_AI_ENABLED=true
EXPO_PUBLIC_WEALTH_TAB_ENABLED=true

# App Store Review Links
# Optional. If omitted, MoneyKai falls back to store search results.
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=

# Optional: Web Google sign-in uses the provider configured in Firebase Auth

# Optional: Enable debug mode
EXPO_PUBLIC_DEBUG=false

# Sentry Monitoring
# EXPO_PUBLIC_SENTRY_DSN is safe for browser use. SENTRY_* values are CI/server
# secrets for source-map upload and API monitoring.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_DEBUG=false
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
SENTRY_DELETE_SOURCE_MAPS_AFTER_UPLOAD=true
