{
  "extends": "../../node_modules/@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "react",
      "react-native",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@moneykai/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@moneykai/domain/*": [
        "../../packages/domain/src/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "index.js",
    "src/config/environment.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/constants/**/*.ts",
    "src/content/**/*.ts",
    "src/contracts/**/*.ts",
    "src/data/**/*.ts",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/hooks/useTheme.ts",
    "src/navigation/**/*.ts",
    "src/navigation/**/*.tsx",
    "src/screens/**/*.tsx",
    "src/services/**/*.ts",
    "src/stores/useAuthStore.ts",
    "src/stores/useSettingsStore.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts",
    "declarations.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "android",
    "ios",
    "src/app/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
