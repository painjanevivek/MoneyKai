{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DEV_CLIENT_BUILD": "true",
        "EXPO_PUBLIC_SMS_RESEARCH_BUILD": "true",
        "EXPO_PUBLIC_NATIVE_SMS_RESEARCH_BUILD": "true"
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DEV_CLIENT_BUILD": "false",
        "EXPO_PUBLIC_SMS_RESEARCH_BUILD": "true",
        "EXPO_PUBLIC_NATIVE_SMS_RESEARCH_BUILD": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "sms-research-local": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DEV_CLIENT_BUILD": "false",
        "EXPO_PUBLIC_SMS_RESEARCH_BUILD": "true",
        "EXPO_PUBLIC_NATIVE_SMS_RESEARCH_BUILD": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DEV_CLIENT_BUILD": "false",
        "EXPO_PUBLIC_SMS_RESEARCH_BUILD": "true",
        "EXPO_PUBLIC_NATIVE_SMS_RESEARCH_BUILD": "false"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
