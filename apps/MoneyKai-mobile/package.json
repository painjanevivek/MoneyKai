  "scripts": {
    "start": "react-native start",
    "build": "npm run android:assemble:debug",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:clean": "cd android && gradlew.bat clean",
    "android:assemble:debug": "cd android && gradlew.bat :app:assembleDebug",
    "android:assemble:release": "npm run android:verify:production-signing -- --mode local-release && cd android && gradlew.bat :app:assembleRelease",
    "android:bundle:release": "npm run android:verify:production-signing -- --mode local-release && cd android && gradlew.bat :app:bundleRelease",
    "android:bundle:release:verify": "npm run android:bundle:release && npm run android:verify:release-permissions -- --aab android/app/build/outputs/bundle/release/app-release.aab",
    "android:capture:handoff": "node ./scripts/capture-android-handoff.mjs",
    "android:verify:production-signing": "node ./scripts/verify-android-production-signing.mjs",
    "android:verify:release-permissions": "node ./scripts/verify-android-release-permissions.mjs",
    "eas-build-on-complete": "sentry-eas-build-on-complete",
    "generate:icons": "node ./scripts/generate-app-icons.mjs",
    "lint": "eslint . --no-cache",
    "typecheck": "tsc --noEmit",
    "test:capture": "vitest run src/services/captureParser.test.ts src/services/captureParserEval.test.ts src/services/captureDedupe.test.ts src/services/captureReviewPolicy.test.ts src/services/aiSmsAssist.test.ts src/services/smsPrivacy.test.ts src/services/backupPrivacy.test.ts src/services/autoCaptureService.test.ts src/services/diagnosticsService.test.ts src/services/diagnosticsUploadService.test.ts src/services/internalTestingReportService.test.ts src/stores/useCaptureStore.test.ts src/config/smsPolicyConfig.test.ts",
    "test:backup-restore": "vitest run src/services/backupPrivacy.test.ts",
    "test:interaction": "vitest run src/services/optimisticMutation.test.ts src/services/progressIllusion.test.ts"
  },
