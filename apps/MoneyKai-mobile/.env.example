# MoneyKai Mobile Environment Variables
# Copy this file to .env and fill in your values.
# React Native Firebase also requires android/app/google-services.json.

# Firebase Configuration
MONEYKAI_FIREBASE_API_KEY=your-firebase-api-key
MONEYKAI_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
MONEYKAI_FIREBASE_PROJECT_ID=your-project-id
MONEYKAI_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
MONEYKAI_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
MONEYKAI_FIREBASE_APP_ID=your-firebase-app-id

# Google Sign-In Configuration
# Android release builds require the web and Android OAuth client IDs.
# Leave the iOS client ID blank until MoneyKai ships on iOS.
MONEYKAI_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
MONEYKAI_GOOGLE_IOS_CLIENT_ID=
MONEYKAI_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com

# FastAPI Backend Configuration
# Used for live news, authenticated sync, backups, and remote data reads/writes.
MONEYKAI_BACKEND_BASE_URL=http://localhost:8000

# App Store Review Links
# Optional. If omitted, MoneyKai falls back to store search results.
MONEYKAI_APP_STORE_URL=
MONEYKAI_PLAY_STORE_URL=

# Optional toggles
MONEYKAI_DEBUG=false
MONEYKAI_DEMO_MODE=false
MONEYKAI_SMS_RESEARCH_BUILD=true
MONEYKAI_NATIVE_SMS_RESEARCH_BUILD=false
