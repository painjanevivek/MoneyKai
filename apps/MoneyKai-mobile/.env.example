# MoneyKai mobile environment template
# Copy to .env for local development and fill in the real values.

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
EXPO_PUBLIC_FIREBASE_ANDROID_APP_ID=your-android-firebase-app-id

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id

# MoneyKai API Configuration
# Use http://localhost:8000 for local backend development.
# Production mobile builds should point to the deployed MoneyKai FastAPI backend.
EXPO_PUBLIC_BACKEND_BASE_URL=https://money-kai-backend.vercel.app

# Sentry Monitoring
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENABLED=true
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_DIST=
EXPO_PUBLIC_SENTRY_ERROR_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=1
EXPO_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1

# General App Flags
EXPO_PUBLIC_DEBUG=false
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_SMS_RESEARCH_BUILD=false
EXPO_PUBLIC_NATIVE_SMS_RESEARCH_BUILD=false

# Financial Surface Rollout Flags
# Gmail requires backend GMAIL_FEATURE_ENABLED, Google OAuth verification,
# and a redirect URI registered for the deployed backend callback.
EXPO_PUBLIC_GMAIL_SYNC_ENABLED=true
EXPO_PUBLIC_PDF_STATEMENT_PARSING_ENABLED=false
EXPO_PUBLIC_WEALTH_TAB_ENABLED=true
EXPO_PUBLIC_FINANCIAL_AI_ENABLED=true

# Store Links
# Optional. If omitted, MoneyKai shows an in-app launch-safe fallback.
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=
