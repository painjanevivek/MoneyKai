{
  "expo": {
    "name": "MoneyKai Mobile",
    "slug": "moneykai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moneykai-mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moneykai.mobile"
    },
    "android": {
      "package": "com.moneykai.mobile",
      "allowBackup": false,
      "predictiveBackGestureEnabled": true,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_MMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.RECEIVE_WAP_PUSH",
        "android.permission.SEND_SMS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_SMS",
        "android.permission.WRITE_CONTACTS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0D8C4C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "MoneyKai uses Face ID or device authentication to protect your account."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D8C4C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MoneyKai needs access to photos to upload receipt images."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0D8C4C"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "MoneyKai needs access to your contacts so you can choose people for split bills."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}

