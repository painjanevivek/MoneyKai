{
  "name": "moneykai-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run mobile:start",
    "web": "npm run web:start",
    "mobile:start": "npm --prefix apps/MoneyKai-mobile run start",
    "mobile:web": "npm --prefix apps/MoneyKai-mobile run web",
    "mobile:android": "npm --prefix apps/MoneyKai-mobile run android",
    "mobile:ios": "npm --prefix apps/MoneyKai-mobile run ios",
    "mobile:lint": "npm --prefix apps/MoneyKai-mobile run lint",
    "mobile:typecheck": "npm --prefix apps/MoneyKai-mobile run typecheck",
    "mobile:test:capture": "npm --prefix apps/MoneyKai-mobile run test:capture",
    "mobile:build": "npm --prefix apps/MoneyKai-mobile run build",
    "mobile:release:android:verify": "npm --prefix apps/MoneyKai-mobile run android:verify:release-permissions --",
    "web:start": "npm --prefix apps/MoneyKai-web run start",
    "web:lint": "npm --prefix apps/MoneyKai-web run lint",
    "web:typecheck": "npm --prefix apps/MoneyKai-web run typecheck",
    "web:build": "npm --prefix apps/MoneyKai-web run build",
    "lint": "npm run mobile:lint && npm run web:lint",
    "typecheck": "npm run mobile:typecheck && npm run web:typecheck",
    "build": "npm run web:build",
    "bootstrap": "npm install --workspaces --include-workspace-root",
    "launch:check": "node ./scripts/launch-check.mjs",
    "security:check": "node ./scripts/owasp-security-check.mjs",
    "indexnow:dry-run": "node ./scripts/indexnow-submit.mjs --dry-run",
    "indexnow:submit": "node ./scripts/indexnow-submit.mjs",
    "backend:dev": "node ./scripts/backend-runner.mjs dev",
    "backend:test": "node ./scripts/backend-runner.mjs test",
    "backend:compile": "node ./scripts/backend-runner.mjs compile",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "playwright:open": "playwright test --ui",
    "playwright:run": "playwright test",
    "e2e:run": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "cypress": "^15.17.0"
  }
}
