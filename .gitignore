# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts
apps/*/.expo/
apps/*/.expo-shared/
apps/*/dist/
apps/*/web-build/
apps/*/expo-env.d.ts

# Native
.kotlin/
.gradle/
**/.gradle/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
!.env.example
!.env*.sample

# typescript
*.tsbuildinfo

# test output
coverage/
.pytest_cache/
__pycache__/
*.py[cod]

# local virtual environments
.venv/
venv/

# local validation artifacts
apps/*/artifacts/**
!apps/*/artifacts/
!apps/*/artifacts/README.md
!apps/*/artifacts/*/
!apps/*/artifacts/*/.gitkeep

# editors
.idea/

example

# generated native folders
apps/*/ios/
apps/*/android/
